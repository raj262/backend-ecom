# --- Server -----------------------------------------------------------
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed browser origins (storefront + admin)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# --- MongoDB Atlas ----------------------------------------------------
# Replace <user>, <password>, <cluster>, and <dbname>
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<dbname>

# --- JWT --------------------------------------------------------------
# Use long random secrets in production
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Auth -------------------------------------------------------------
BCRYPT_SALT_ROUNDS=10

# --- Redis (recommended in prod) --------------------------------------
# When set, enables:
#   - BullMQ durable queues for invoice / notification / analytics jobs
#   - Tiered cache (in-memory L1 + Redis L2) shared across instances
# When unset:
#   - Queue jobs execute inline (single-process, no retries)
#   - Cache is in-memory only (will diverge across replicas)
# REDIS_URL=redis://localhost:6379

# --- Payment gateways (optional) --------------------------------------
# Leaving these blank keeps providers in "dev" mode (mock checkout, trust
# client signature). Set both halves before going to production.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# EASEBUZZ_KEY=
# EASEBUZZ_SALT=
